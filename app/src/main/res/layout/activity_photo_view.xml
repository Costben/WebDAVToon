<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <erl.webdavtoon.ZoomableRecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 快速滚动条容器 -->
    <FrameLayout
        android:id="@+id/fastScrollContainer"
        android:layout_width="12dp"
        android:layout_height="0dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_fast_scroll_pill"
        android:elevation="4dp"
        android:padding="2dp"
        android:visibility="gone">

        <View
            android:id="@+id/fastScrollThumb"
            android:layout_width="8dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_fast_scroll_thumb"
            android:alpha="0.8" />
    </FrameLayout>

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIconTint="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 底栏 -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        app:fabAlignmentMode="center"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp"
        app:contentInsetLeft="0dp"
        app:contentInsetRight="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 文件详情图标 -->
            <ImageButton
                android:id="@+id/detailButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_info_circle"
                android:contentDescription="@string/detail"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/favoriteButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="1" />

            <!-- 收藏图标 -->
            <ImageButton
                android:id="@+id/favoriteButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_star"
                android:contentDescription="@string/favorites"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/detailButton"
                app:layout_constraintRight_toLeftOf="@+id/modeSwitchButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_weight="1" />

            <!-- 模式切换按钮 -->
            <ImageButton
                android:id="@+id/modeSwitchButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_transition_right"
                android:contentDescription="@string/mode_switch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/favoriteButton"
                app:layout_constraintRight_toLeftOf="@+id/immersiveButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_weight="1" />

            <!-- 沉浸模式切换按钮 -->
            <ImageButton
                android:id="@+id/immersiveButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_maximize"
                android:contentDescription="@string/immersive_switch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/modeSwitchButton"
                app:layout_constraintRight_toLeftOf="@+id/selectButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_weight="1" />

            <!-- 多选模式切换按钮 -->
            <ImageButton
                android:id="@+id/selectButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_check_circle"
                android:contentDescription="@string/select"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/immersiveButton"
                app:layout_constraintRight_toLeftOf="@+id/downloadButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_weight="1" />

            <!-- 下载图标 -->
            <ImageButton
                android:id="@+id/downloadButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_download"
                android:contentDescription="@string/download"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/selectButton"
                app:layout_constraintRight_toLeftOf="@+id/deleteButton"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_weight="1" />

            <!-- 删除图标 -->
            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_ior_trash"
                android:contentDescription="@string/delete"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/downloadButton"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintHorizontal_weight="1" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.bottomappbar.BottomAppBar>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
